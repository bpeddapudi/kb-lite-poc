# Copy to `.env` and set your public token (https://account.mapbox.com/)
# Vite only exposes vars prefixed with VITE_
#
# GitHub Pages / CI: add the same name as a repository secret (Settings → Secrets and variables →
# Actions) so `npm run build` in GitHub Actions receives it. The value is still embedded in the
# published JS (unavoidable for browser maps); restrict the token by URL in the Mapbox dashboard.
VITE_MAPBOX_TOKEN=
